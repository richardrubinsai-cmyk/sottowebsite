<footer class="px-6 py-16">
  <div class="mx-auto max-w-5xl">
    <!-- Row 1 -->
    <div class="grid grid-cols-1 gap-8 md:grid-cols-3 md:items-end">
      <div>
        <span class="font-serif text-3xl tracking-[0.2em] text-cream">Sotto</span>
      </div>
      <div>
        <p class="font-serif italic text-sm leading-relaxed text-muted md:text-base">
          Quiet systems for serious operators.
        </p>
      </div>
      <div aria-hidden="true"></div>
    </div>

    <!-- Row 2: hairline divider -->
    <div
      class="mt-12 h-px w-full"
      style="background-color: rgba(184,150,75,0.2);"
      aria-hidden="true"
    ></div>

    <!-- Row 3 -->
    <div class="mt-10 grid grid-cols-1 gap-4 md:grid-cols-3 md:items-center">
      <p class="font-sans text-xs text-muted">&copy; 2026 Sotto</p>
      <div class="font-sans text-xs text-muted md:text-center">
        <p>An independent project.</p>
        <p class="mt-2">bysotto.com</p>
      </div>
      <div class="flex gap-6 md:justify-end">
        <a
          href="#"
          class="font-sans text-xs text-muted transition-colors duration-200 hover:text-brass"
        >Privacy</a>
        <a
          href="#"
          class="font-sans text-xs text-muted transition-colors duration-200 hover:text-brass"
        >Terms</a>
      </div>
    </div>
  </div>
