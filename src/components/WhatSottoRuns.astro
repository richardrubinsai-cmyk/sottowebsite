---
const outcomes = [
  {
    label: "Lead Intake",
    title: "Every form fill, routed in seconds.",
    body: "Every form fill enriched and routed to Slack in under 30 seconds. Auto-response goes out before they close the tab.",
  },
  {
    label: "Proposal Engine",
    title: "Intake call to first draft in 15 minutes.",
    body: "Intake call to first-draft proposal in 15 minutes, not 3 hours.",
  },
  {
    label: "Client Reporting",
    title: "Weekly reports go out without you.",
    body: "Weekly automated reports to your clients, branded as yours.",
  },
  {
    label: "Inbox + Follow-up",
    title: "Nothing drops between meetings.",
    body: "Drafts ready, stale leads chased, nothing dropped between meetings.",
  },
];
---

<section class="section-band section-band--outcomes reveal px-6 py-28 md:py-40">
  <div class="mx-auto max-w-6xl">
    <div class="grid gap-12 md:grid-cols-[0.9fr_1.4fr] md:items-end">
      <div>
        <p class="eyebrow">What we build</p>
        <h2 class="mt-6 font-serif text-4xl font-normal leading-tight text-cream md:text-5xl">
          What we build for you.
        </h2>
      </div>
      <p class="max-w-[34rem] font-sans text-base leading-relaxed text-muted md:justify-self-end md:text-lg">
        Seven workflows that turn the busy work into background work.
      </p>
    </div>

    <div class="outcome-grid mt-16 grid grid-cols-1 md:grid-cols-4">
      {outcomes.map((item) => (
        <article class="outcome-card">
          <span>{item.label}</span>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .outcome-grid {
    border-top: 1px solid rgba(245, 241, 232, 0.09);
    border-left: 1px solid rgba(245, 241, 232, 0.08);
  }

  .outcome-card {
    min-height: 260px;
    padding: 28px;
    border-right: 1px solid rgba(245, 241, 232, 0.08);
    border-bottom: 1px solid rgba(245, 241, 232, 0.08);
    background:
      linear-gradient(180deg, rgba(245, 241, 232, 0.035), transparent),
      rgba(10, 10, 10, 0.22);
  }

  .outcome-card span {
    color: var(--color-brass);
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .outcome-card h3 {
    margin: 54px 0 0;
    color: var(--color-cream);
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.01em;
  }

  .outcome-card p {
    margin: 18px 0 0;
    color: var(--color-muted);
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.65;
  }

  @media (max-width: 767px) {
    .outcome-grid {
      margin-top: 44px;
    }

    .outcome-card {
      min-height: auto;
      padding: 22px;
    }

    .outcome-card h3 {
      margin-top: 28px;
      font-size: 24px;
      line-height: 1.12;
    }

    .outcome-card p {
      font-size: 13px;
      line-height: 1.62;
    }
  }
</style>
