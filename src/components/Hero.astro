---
import HeroSparklesBackground from "./HeroSparklesBackground";
---

<section data-hero-section class="relative min-h-screen w-full overflow-hidden">
  <HeroSparklesBackground client:load />
  <!-- Background atmospherics -->
  <div class="hero-glow" aria-hidden="true"></div>
  <div class="hero-glow-accent" aria-hidden="true"></div>
  <div class="streak streak-1" aria-hidden="true"></div>
  <div class="streak streak-2" aria-hidden="true"></div>

  <!-- Two-zone grid -->
  <div class="relative z-20 grid min-h-screen grid-cols-1 md:grid-cols-[5fr_6fr]">
    <!-- Left text zone -->
    <div class="flex min-h-screen items-center px-8 pb-20 pt-32 md:pl-14 md:pr-20 md:pt-0">
      <div class="max-w-[40rem]">
        <p class="eyebrow">Quiet systems for serious operators.</p>

        <h1
          class="mt-10 font-serif font-normal text-cream"
          style="font-size: clamp(4rem, 9.6vw, 8rem); letter-spacing: -0.02em; line-height: 0.95;"
        >
          The operator&rsquo;s<br />AI stack.
        </h1>

        <p class="mt-10 max-w-[28rem] font-sans text-base leading-relaxed text-muted md:text-lg">
          Seven workflows. One system. Built for the people doing the work alone.
        </p>

        <div class="mt-12">
          <a
            href="#waitlist"
            class="hero-cta inline-block border border-brass px-8 py-3.5 font-sans text-xs uppercase tracking-[0.24em] text-brass hover:bg-brass hover:text-bg"
          >
            Join the waitlist
          </a>
        </div>
      </div>
    </div>

    <!-- Right zone: layered product mockup composition -->
    <div class="relative hidden md:block" aria-hidden="true">
      <div class="mockup-stage" data-parallax-stage>
        <!-- Element C — n8n workflow snippet (back) -->
        <div
          class="mockup mockup-n8n"
          data-parallax="0.7"
          style="--rest-transform: rotate(-4deg); animation-delay: 800ms;"
        >
          <svg viewBox="0 0 220 140" xmlns="http://www.w3.org/2000/svg" width="220" height="140">
            <rect width="220" height="140" rx="6" fill="#1A1A1A" stroke="#2A2A2A"/>
            <!-- grid -->
            <g opacity="0.25" stroke="#3A3A3A" stroke-width="0.5">
              <path d="M0 30 H220 M0 60 H220 M0 90 H220 M0 120 H220" />
              <path d="M30 0 V140 M60 0 V140 M90 0 V140 M120 0 V140 M150 0 V140 M180 0 V140" />
            </g>
            <!-- connection curves -->
            <path d="M40 70 C 60 70, 60 40, 80 40" stroke="#7A5BFF" stroke-width="1" fill="none" opacity="0.7"/>
            <path d="M100 40 C 120 40, 120 70, 140 70" stroke="#7A5BFF" stroke-width="1" fill="none" opacity="0.7"/>
            <path d="M100 40 C 120 40, 120 100, 140 100" stroke="#1FBAD6" stroke-width="1" fill="none" opacity="0.7"/>
            <path d="M160 70 C 180 70, 180 100, 200 100" stroke="#1FBAD6" stroke-width="1" fill="none" opacity="0.7"/>
            <!-- nodes -->
            <g>
              <rect x="20" y="58" width="22" height="22" rx="4" fill="#222" stroke="#7A5BFF" stroke-width="1"/>
              <circle cx="31" cy="69" r="3" fill="#7A5BFF"/>
            </g>
            <g>
              <rect x="78" y="28" width="22" height="22" rx="4" fill="#222" stroke="#7A5BFF" stroke-width="1"/>
              <circle cx="89" cy="39" r="3" fill="#7A5BFF"/>
            </g>
            <g>
              <rect x="138" y="58" width="22" height="22" rx="4" fill="#222" stroke="#1FBAD6" stroke-width="1"/>
              <circle cx="149" cy="69" r="3" fill="#1FBAD6"/>
            </g>
            <g>
              <rect x="138" y="88" width="22" height="22" rx="4" fill="#222" stroke="#1FBAD6" stroke-width="1"/>
              <circle cx="149" cy="99" r="3" fill="#1FBAD6"/>
            </g>
            <g>
              <rect x="196" y="88" width="22" height="22" rx="4" fill="#222" stroke="#1FBAD6" stroke-width="1"/>
              <circle cx="207" cy="99" r="3" fill="#1FBAD6"/>
            </g>
          </svg>
        </div>

        <!-- Element B — Daily Brief preview (mid) -->
        <div
          class="mockup mockup-brief"
          data-parallax="0.85"
          style="--rest-transform: rotate(3deg); animation-delay: 600ms;"
        >
          <div class="brief-card">
            <div class="brief-header">
              <span class="brief-eyebrow">Daily Brief</span>
              <span class="brief-day">Tuesday</span>
            </div>
            <ul class="brief-list">
              <li><span class="brief-num">3</span> calls today <span class="brief-meta">(first at 10:30 — Marcus Chen, prospect)</span></li>
              <li><span class="brief-num">2</span> invoices overdue <span class="brief-meta">(£4,200 — chase scripts ready)</span></li>
              <li><span class="brief-num">1</span> proposal due Friday <span class="brief-meta">(Henderson — draft 80%)</span></li>
            </ul>
          </div>
        </div>

        <!-- Element A — Telegram message (front) -->
        <div
          class="mockup mockup-tg"
          data-parallax="1.0"
          style="--rest-transform: rotate(-2deg); animation-delay: 400ms;"
        >
          <div class="tg-card">
            <div class="tg-header">
              <div class="tg-avatar">S</div>
              <div class="tg-meta">
                <div class="tg-name">Sotto</div>
                <div class="tg-status">bot</div>
              </div>
            </div>
            <div class="tg-body">
              <div class="tg-bubble">
                <div class="tg-bubble-title">🟡 HOT LEAD — Score 8/10</div>
                <div class="tg-line">From: marcus.chen@company.com</div>
                <div class="tg-line">Subject: Re: Looking for Q1 automation help</div>
                <div class="tg-spacer"></div>
                <div class="tg-line tg-faint">Match: pricing question + buying signal</div>
                <div class="tg-line tg-faint">Suggested reply drafted — review in 2min</div>
                <div class="tg-time">09:47</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Stage */
  .mockup-stage {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .mockup {
    position: absolute;
    transform: var(--rest-transform);
    opacity: 1;
    transform-origin: center center;
  }

  /* C — n8n */
  .mockup-n8n {
    top: 18%;
    left: 6%;
    width: 220px;
    opacity: 0.6;
    filter: blur(1px);
  }

  /* B — Brief */
  .mockup-brief {
    top: 14%;
    right: 8%;
    width: 280px;
  }
  .brief-card {
    background: #1A1A1A;
    border: 1px solid rgba(184,150,75,0.32);
    padding: 22px 22px 20px;
    box-shadow: 0 24px 60px rgba(0,0,0,0.65), 0 0 0 1px rgba(0,0,0,0.4);
  }
  .brief-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-bottom: 1px solid rgba(184,150,75,0.15);
    padding-bottom: 10px;
  }
  .brief-eyebrow {
    font-family: var(--font-serif);
    font-size: 18px;
    color: var(--color-cream);
    letter-spacing: 0.04em;
  }
  .brief-day {
    font-family: var(--font-sans);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--color-brass);
  }
  .brief-list {
    margin-top: 12px;
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .brief-list li {
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--color-cream);
    line-height: 1.45;
  }
  .brief-num {
    font-family: var(--font-serif);
    color: var(--color-brass);
    font-size: 14px;
    margin-right: 4px;
  }
  .brief-meta {
    color: var(--color-muted);
    font-size: 11px;
  }

  /* A — Telegram */
  .mockup-tg {
    top: 38%;
    right: 18%;
    width: 340px;
    z-index: 3;
  }
  .tg-card {
    background: #212121;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 30px 60px rgba(0,0,0,0.65), 0 0 0 1px rgba(255,255,255,0.04);
  }
  .tg-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: #2C2C2C;
    border-bottom: 1px solid #1A1A1A;
  }
  .tg-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #5288C1;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-size: 16px;
  }
  .tg-meta { line-height: 1.2; }
  .tg-name { color: #fff; font-size: 13px; font-weight: 500; font-family: -apple-system, "Segoe UI", sans-serif; }
  .tg-status { color: #8E8E8E; font-size: 11px; font-family: -apple-system, "Segoe UI", sans-serif; }
  .tg-body {
    padding: 16px 14px;
    display: flex;
    justify-content: flex-end;
  }
  .tg-bubble {
    background: #2B5278;
    color: #fff;
    border-radius: 12px 12px 4px 12px;
    padding: 12px 14px 10px;
    max-width: 280px;
    font-family: -apple-system, "Segoe UI", sans-serif;
    font-size: 13px;
    line-height: 1.45;
    box-shadow: 0 2px 8px rgba(0,0,0,0.4);
  }
  .tg-bubble-title { font-weight: 600; margin-bottom: 6px; }
  .tg-line { font-size: 12.5px; }
  .tg-faint { color: rgba(255,255,255,0.78); font-size: 12px; }
  .tg-spacer { height: 6px; }
  .tg-time {
    text-align: right;
    margin-top: 4px;
    color: rgba(255,255,255,0.55);
    font-size: 10px;
  }

  /* Mobile: collapse stage */
  @media (max-width: 767px) {
    .mockup-stage { display: none; }
    .hero-glow { left: -10%; top: 8%; width: 540px; height: 540px; }
  }
</style>

<script>
  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const els = Array.from(document.querySelectorAll<HTMLElement>("[data-parallax]"));

  // Staggered entrance: 400ms initial, 200ms between elements (back → mid → front)
  if (!prefersReduced && els.length) {
    const ordered = els.slice().sort((a, b) =>
      parseFloat(a.dataset.parallax || "1") - parseFloat(b.dataset.parallax || "1")
    );
    ordered.forEach((el, i) => {
      setTimeout(() => el.classList.add("mockup-in"), 400 + i * 200);
    });
  } else {
    els.forEach((el) => el.classList.add("mockup-in"));
  }

  // Throttled parallax (skip on reduced motion)
  if (!prefersReduced && els.length) {
    let ticking = false;
    let lastY = window.scrollY;
    const apply = () => {
      for (const el of els) {
        const speed = parseFloat(el.dataset.parallax || "1");
        el.style.transform = `var(--rest-transform) translateY(${(-lastY * speed * 0.15).toFixed(1)}px)`;
      }
      ticking = false;
    };
    window.addEventListener(
      "scroll",
      () => {
        lastY = window.scrollY;
        if (!ticking) {
          ticking = true;
          setTimeout(apply, 16);
        }
      },
      { passive: true }
    );
  }
</script>
