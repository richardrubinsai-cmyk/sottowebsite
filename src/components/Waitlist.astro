<section id="waitlist" class="section-band section-band--waitlist reveal px-6 py-28 md:py-40">
  <div class="mx-auto" style="max-width: 560px;">
    <div class="text-center">
      <p class="eyebrow" style="display:inline-flex;">Early Access</p>
      <h2 class="mt-6 font-serif text-4xl font-normal leading-tight text-cream md:text-5xl">
        Request early access.
      </h2>
      <p class="mt-5 font-sans text-base leading-relaxed text-muted">
        Get the private launch build, workflow map, setup notes, and first access to the operator brief system.
      </p>
    </div>

    <div class="access-includes mt-12">
      <div>
        <span>01</span>
        <p>Private launch build</p>
      </div>
      <div>
        <span>02</span>
        <p>Workflow map + setup notes</p>
      </div>
      <div>
        <span>03</span>
        <p>Direct founder access</p>
      </div>
    </div>

    <div class="waitlist-cta mt-16" id="waitlist-cta">
      <a
        href="https://buy.stripe.com/5kQbJ0bFkeTm1PQ6WR53O01"
        target="_blank"
        rel="noopener noreferrer"
        class="cta-button"
      >
        Get the Playbook — £47
      </a>
    </div>
  </div>
</section>

<style>
  .access-includes {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid rgba(184, 150, 75, 0.24);
    border-left: 1px solid rgba(245, 241, 232, 0.08);
  }

  .access-includes div {
    min-height: 112px;
    padding: 18px;
    border-right: 1px solid rgba(245, 241, 232, 0.08);
    border-bottom: 1px solid rgba(245, 241, 232, 0.08);
    background: rgba(10, 10, 10, 0.22);
  }

  .access-includes span {
    color: var(--color-brass);
    font-family: var(--font-display);
    font-size: 18px;
  }

  .access-includes p {
    margin: 22px 0 0;
    color: rgba(245, 241, 232, 0.76);
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 1.45;
  }

  .waitlist-cta {
    text-align: center;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 56px;
    border: 1px solid var(--color-brass);
    background: transparent;
    color: var(--color-brass);
    font-family: var(--font-serif);
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    text-decoration: none;
    transition: background-color 280ms ease, color 280ms ease;
  }

  .cta-button:hover {
    background: var(--color-brass);
    color: var(--color-bg);
  }

  @media (max-width: 640px) {
    .access-includes {
      grid-template-columns: 1fr;
      margin-top: 36px;
    }

    .access-includes div {
      min-height: auto;
      padding: 16px 18px;
      display: grid;
      grid-template-columns: 44px minmax(0, 1fr);
      align-items: baseline;
      gap: 12px;
    }

    .access-includes p {
      margin: 0;
      font-size: 13px;
    }

    .cta-button {
      height: 58px;
      font-size: 13px;
      letter-spacing: 0.16em;
    }
  }
</style>
