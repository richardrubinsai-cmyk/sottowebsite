---
---

<section id="waitlist" class="section-band section-band--waitlist reveal px-6 py-28 md:py-40">
  <div class="mx-auto" style="max-width: 560px;">
    <div class="text-center">
      <p class="eyebrow" style="display:inline-flex;">Now Available</p>
      <h2 class="mt-6 font-serif text-4xl font-normal leading-tight text-cream md:text-5xl">
        Get the Playbook.
      </h2>
      <p class="mt-5 font-sans text-base leading-relaxed text-muted">
        The complete AI/automation stack for serious operators. Instant PDF delivery on purchase.
      </p>
    </div>

    <div class="access-includes mt-12">
      <div>
        <span>01</span>
        <p>Private launch build</p>
      </div>
      <div>
        <span>02</span>
        <p>Workflow map + setup notes</p>
      </div>
      <div>
        <span>03</span>
        <p>Direct founder access</p>
      </div>
    </div>

    <div class="waitlist-cta mt-16" id="waitlist-cta">
      <a
        href="#pricing"
        class="cta-button"
      >
        Get the Playbook
      </a>
    </div>
  </div>

  <div id="pricing" class="pricing-grid mx-auto mt-20" style="max-width: 1080px;">

    <div class="pricing-card">
      <p class="pricing-tier-name">The Playbook</p>
      <p class="pricing-price">£47</p>
      <ul class="pricing-items">
        <li>PDF playbook</li>
        <li>7 n8n workflow files</li>
        <li>Setup guide</li>
      </ul>
      <a
        href="https://buy.stripe.com/5kQbJ0bFkeTm1PQ6WR53O01"
        target="_blank"
        rel="noopener noreferrer"
        class="pricing-btn"
      >Buy Now</a>
    </div>

    <div class="pricing-card pricing-card--featured">
      <p class="pricing-badge">Recommended</p>
      <p class="pricing-tier-name">The Operator Pack</p>
      <p class="pricing-price">£147</p>
      <ul class="pricing-items">
        <li>Everything in Playbook</li>
        <li>Prompt library</li>
        <li>Loom video walkthroughs</li>
        <li>Ready-to-import n8n templates</li>
      </ul>
      <a href="#" class="pricing-btn">Buy Now</a>
    </div>

    <div class="pricing-card">
      <p class="pricing-tier-name">Done For You</p>
      <p class="pricing-price">£1,500</p>
      <ul class="pricing-items">
        <li>Full system built and installed on your account</li>
        <li>Credentials configured, tested end-to-end</li>
        <li>30-min kickoff call</li>
      </ul>
      <a href="#" class="pricing-btn">Apply Now</a>
    </div>

  </div>
</section>

<style>
  .access-includes {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid rgba(184, 150, 75, 0.24);
    border-left: 1px solid rgba(245, 241, 232, 0.08);
  }

  .access-includes div {
    min-height: 112px;
    padding: 18px;
    border-right: 1px solid rgba(245, 241, 232, 0.08);
    border-bottom: 1px solid rgba(245, 241, 232, 0.08);
    background: rgba(10, 10, 10, 0.22);
  }

  .access-includes span {
    color: var(--color-brass);
    font-family: var(--font-display);
    font-size: 18px;
  }

  .access-includes p {
    margin: 22px 0 0;
    color: rgba(245, 241, 232, 0.76);
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 1.45;
  }

  .waitlist-cta {
    text-align: center;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 56px;
    border: 1px solid var(--color-brass);
    background: transparent;
    color: var(--color-brass);
    font-family: var(--font-serif);
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    text-decoration: none;
    transition: background-color 280ms ease, color 280ms ease;
  }

  .cta-button:hover {
    background: var(--color-brass);
    color: var(--color-bg);
  }

  /* ── Pricing grid ── */
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(184, 150, 75, 0.18);
    border: 1px solid rgba(184, 150, 75, 0.18);
  }

  .pricing-card {
    display: flex;
    flex-direction: column;
    padding: 36px 32px 32px;
    background: rgba(10, 10, 10, 0.72);
    position: relative;
  }

  .pricing-card--featured {
    background: rgba(184, 150, 75, 0.06);
    outline: 1px solid var(--color-brass);
    outline-offset: -1px;
    z-index: 1;
  }

  .pricing-badge {
    font-family: var(--font-sans);
    font-size: 9px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-brass);
    margin: 0 0 16px;
  }

  .pricing-tier-name {
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 400;
    color: var(--color-cream);
    margin: 0 0 12px;
  }

  /* push tier name down to align with featured card that has the badge */
  .pricing-card:not(.pricing-card--featured) .pricing-tier-name {
    margin-top: 25px;
  }

  .pricing-price {
    font-family: var(--font-display);
    font-size: 36px;
    color: var(--color-brass);
    margin: 0 0 28px;
    letter-spacing: 0.02em;
  }

  .pricing-items {
    list-style: none;
    padding: 0;
    margin: 0 0 32px;
    flex: 1;
    border-top: 1px solid rgba(245, 241, 232, 0.08);
    padding-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .pricing-items li {
    font-family: var(--font-sans);
    font-size: 13px;
    color: rgba(245, 241, 232, 0.72);
    line-height: 1.45;
    padding-left: 16px;
    position: relative;
  }

  .pricing-items li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--color-brass);
    opacity: 0.6;
  }

  .pricing-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 48px;
    border: 1px solid var(--color-brass);
    background: transparent;
    color: var(--color-brass);
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    text-decoration: none;
    transition: background-color 260ms ease, color 260ms ease;
    margin-top: auto;
  }

  .pricing-btn:hover {
    background: var(--color-brass);
    color: var(--color-bg);
  }

  @media (max-width: 640px) {
    .access-includes {
      grid-template-columns: 1fr;
      margin-top: 36px;
    }

    .access-includes div {
      min-height: auto;
      padding: 16px 18px;
      display: grid;
      grid-template-columns: 44px minmax(0, 1fr);
      align-items: baseline;
      gap: 12px;
    }

    .access-includes p {
      margin: 0;
      font-size: 13px;
    }

    .cta-button {
      height: 58px;
      font-size: 13px;
      letter-spacing: 0.16em;
    }

    .pricing-grid {
      grid-template-columns: 1fr;
    }

    .pricing-card:not(.pricing-card--featured) .pricing-tier-name {
      margin-top: 0;
    }

    .pricing-card {
      padding: 28px 22px 24px;
    }

    .pricing-price {
      font-size: 30px;
    }
  }
</style>
