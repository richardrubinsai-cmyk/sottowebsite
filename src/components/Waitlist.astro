---
---

<section id="pricing" class="section-band section-band--waitlist reveal px-6 py-28 md:py-40">
  <div class="mx-auto" style="max-width: 640px;">
    <div class="text-center">
      <p class="eyebrow" style="display:inline-flex;">Pricing</p>
      <h2 class="mt-6 font-serif text-4xl font-normal leading-tight text-cream md:text-5xl">
        One offer. Built in 7 days.
      </h2>
      <p class="mt-5 font-sans text-base leading-relaxed text-muted">
        No tiers, no upsell. One productized build, then maintained for you every month.
      </p>
    </div>
  </div>

  <div class="agency-card mx-auto mt-16">
    <p class="agency-eyebrow">The Agency Engine</p>

    <div class="agency-price-block">
      <div class="agency-price-row">
        <span class="agency-price-label">Setup</span>
        <span class="agency-price-value">£1,500</span>
        <span class="agency-price-suffix">one-time</span>
      </div>
      <div class="agency-price-row">
        <span class="agency-price-label">Then</span>
        <span class="agency-price-value">£450</span>
        <span class="agency-price-suffix">/ month &middot; 3-month minimum</span>
      </div>
    </div>

    <p class="agency-includes-label">What you get</p>
    <ul class="agency-items">
      <li>7 workflows built and installed on your accounts</li>
      <li>Lead intake, proposal engine, client reporting, follow-up automation</li>
      <li>Discovery call + 7-day build + Loom walkthrough</li>
      <li>Monthly maintenance, monitoring, minor changes</li>
      <li>Direct access &mdash; we fix things the same day</li>
    </ul>

    <div class="agency-guarantee">
      <p class="agency-guarantee-label">Guarantee</p>
      <p class="agency-guarantee-body">
        If your Agency Engine isn&rsquo;t live and working within 7 business days, you get the setup fee back. No questions.
      </p>
    </div>

    <a
      href="https://calendly.com/bysottoco/30min"
      target="_blank"
      rel="noopener noreferrer"
      class="agency-cta"
    >
      Book a 15-min audit call
    </a>
  </div>

  <p class="agency-footnote mx-auto mt-12">
    Not sure if it&rsquo;s a fit? The audit call is 15 minutes, no pitch. We tell you whether automation will move the needle for you, or it won&rsquo;t.
  </p>
</section>

<style>
  .agency-card {
    max-width: 640px;
    padding: 48px 44px 44px;
    background: rgba(10, 10, 10, 0.72);
    border: 1px solid rgba(184, 150, 75, 0.42);
    outline: 1px solid rgba(184, 150, 75, 0.12);
    outline-offset: 6px;
    position: relative;
  }

  .agency-eyebrow {
    margin: 0 0 28px;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: var(--color-brass);
    text-align: center;
  }

  .agency-price-block {
    border-top: 1px solid rgba(245, 241, 232, 0.08);
    border-bottom: 1px solid rgba(245, 241, 232, 0.08);
    padding: 22px 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .agency-price-row {
    display: grid;
    grid-template-columns: 64px auto 1fr;
    align-items: baseline;
    gap: 16px;
  }

  .agency-price-label {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: rgba(245, 241, 232, 0.58);
  }

  .agency-price-value {
    font-family: var(--font-display);
    font-size: 40px;
    color: var(--color-brass);
    letter-spacing: 0.01em;
    line-height: 1;
  }

  .agency-price-suffix {
    font-family: var(--font-body);
    font-size: 12px;
    color: rgba(245, 241, 232, 0.62);
  }

  .agency-includes-label {
    margin: 32px 0 16px;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: rgba(245, 241, 232, 0.58);
  }

  .agency-items {
    list-style: none;
    padding: 0;
    margin: 0 0 32px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .agency-items li {
    font-family: var(--font-body);
    font-size: 14px;
    color: rgba(245, 241, 232, 0.82);
    line-height: 1.5;
    padding-left: 18px;
    position: relative;
  }

  .agency-items li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--color-brass);
    opacity: 0.7;
  }

  .agency-guarantee {
    padding: 20px 22px;
    margin: 0 0 32px;
    background: rgba(184, 150, 75, 0.07);
    border-left: 2px solid var(--color-brass);
  }

  .agency-guarantee-label {
    margin: 0 0 8px;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--color-brass);
  }

  .agency-guarantee-body {
    margin: 0;
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.55;
    color: var(--color-cream);
  }

  .agency-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 56px;
    border: 1px solid var(--color-brass);
    background: var(--color-brass);
    color: var(--color-bg);
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    text-decoration: none;
    transition: background-color 260ms ease, color 260ms ease, border-color 260ms ease;
  }

  .agency-cta:hover {
    background: transparent;
    color: var(--color-brass);
  }

  .agency-footnote {
    max-width: 560px;
    text-align: center;
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-muted);
  }

  @media (max-width: 640px) {
    .agency-card {
      padding: 32px 22px 28px;
      outline-offset: 4px;
    }

    .agency-price-row {
      grid-template-columns: 1fr;
      gap: 4px;
    }

    .agency-price-value {
      font-size: 34px;
    }

    .agency-cta {
      height: 58px;
      font-size: 12px;
      letter-spacing: 0.16em;
    }

    .agency-footnote {
      font-size: 13px;
    }
  }
</style>
