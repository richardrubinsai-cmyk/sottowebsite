<section class="section-band section-band--proof reveal px-6 py-28 md:py-40">
  <div class="mx-auto max-w-5xl">
    <div class="brand-statement">
      <p class="eyebrow">WHY IT EXISTS</p>
      <h2>
        Built for the operator.<br />
        Not the agency.
      </h2>
      <p>
        Sotto exists because most AI tools are built for teams with ops budgets. Solo operators get the same complexity with none of the support. Sotto is the operating layer that runs in the background.
      </p>
    </div>
  </div>
</section>

<style>
  .brand-statement {
    border-left: 1px solid rgba(184, 150, 75, 0.38);
    padding-left: 34px;
  }

  .brand-statement h2 {
    max-width: 720px;
    margin: 26px 0 0;
    color: var(--color-cream);
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 3rem);
    font-weight: 400;
    line-height: 1.05;
  }

  .brand-statement > p:last-child {
    max-width: 560px;
    margin: 30px 0 0;
    color: rgba(245, 241, 232, 0.62);
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.7;
  }

  @media (max-width: 767px) {
    .brand-statement {
      padding-left: 18px;
    }

    .brand-statement h2 {
      font-size: clamp(2.15rem, 11vw, 2.55rem);
      line-height: 1.06;
    }

    .brand-statement > p:last-child {
      margin-top: 24px;
      font-size: 14px;
      line-height: 1.65;
    }
  }
</style>
