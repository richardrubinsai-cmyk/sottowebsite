---
const steps = [
  {
    step: "01",
    title: "Discovery (30 mins).",
    body: "We map your current workflow: where leads come in, how proposals get made, where time is leaking.",
  },
  {
    step: "02",
    title: "Build (7 business days).",
    body: "We build, install, and test everything on your accounts. Credentials configured, integrations tested, error handling in place.",
  },
  {
    step: "03",
    title: "Maintained forever.",
    body: "We monitor, fix, and improve the system every month. APIs change, we handle it. You never touch n8n.",
  },
];
---

<section id="how" class="section-band section-band--process reveal px-6 py-28 md:py-40">
  <div class="mx-auto max-w-5xl">
    <div class="mx-auto max-w-content text-center">
      <p class="eyebrow" style="display:inline-flex;">How It Works</p>
      <h2 class="mt-6 font-serif text-4xl font-normal leading-tight text-cream md:text-5xl">
        Less app. More operating layer.
      </h2>
      <p class="mx-auto mt-5 max-w-[35rem] font-sans text-base leading-relaxed text-muted md:text-lg">
        The product is the routing, the judgment, and the daily operating rhythm. The interface is only there when it has something useful to say.
      </p>
    </div>

    <div class="process-list mt-18 md:mt-20">
      {steps.map((item) => (
        <article class="process-step">
          <span>{item.step}</span>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .process-list {
    border-top: 1px solid rgba(184, 150, 75, 0.2);
  }

  .process-step {
    display: grid;
    grid-template-columns: 72px minmax(0, 0.8fr) minmax(0, 1fr);
    gap: 32px;
    align-items: baseline;
    padding: 34px 0;
    border-bottom: 1px solid rgba(245, 241, 232, 0.08);
  }

  .process-step span {
    color: rgba(184, 150, 75, 0.86);
    font-family: var(--font-display);
    font-size: 24px;
  }

  .process-step h3 {
    margin: 0;
    color: var(--color-cream);
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.01em;
  }

  .process-step p {
    margin: 0;
    color: var(--color-muted);
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.7;
  }

  @media (max-width: 767px) {
    .process-list {
      margin-top: 46px;
    }

    .process-step {
      grid-template-columns: 1fr;
      gap: 12px;
      padding: 26px 0;
    }

    .process-step span {
      font-size: 22px;
    }

    .process-step h3 {
      font-size: 25px;
      line-height: 1.14;
    }

    .process-step p {
      font-size: 14px;
      line-height: 1.62;
    }
  }
</style>
