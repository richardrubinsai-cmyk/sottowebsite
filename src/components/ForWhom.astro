---
const forYou = [
  "You run a business with one set of hands.",
  "You're tired of manual admin eating your week.",
  "You'd rather own a system than rent five subscriptions.",
  "You can read JSON without panicking.",
];

const notForYou = [
  "You have a team handling ops.",
  "You want plug-and-play with zero setup.",
  "You're looking for a course about AI.",
];
---

<section id="fit" class="section-band section-band--fit reveal px-6 py-28 md:py-40">
  <div class="mx-auto max-w-content">
    <div class="text-center"><p class="eyebrow" style="display:inline-flex;">Fit Check</p></div>

    <div class="relative mt-16 grid grid-cols-1 gap-16 md:grid-cols-2 md:gap-16">
      <!-- vertical brass divider, desktop only -->
      <div
        class="pointer-events-none absolute left-1/2 top-0 hidden h-full w-px -translate-x-1/2 md:block"
        style="background-color: rgba(184,150,75,0.2);"
        aria-hidden="true"
      ></div>

      <div class="md:pr-12">
        <h2 class="font-serif text-2xl font-normal text-cream md:text-3xl">
          This is for you if
        </h2>
        <ul class="mt-8 space-y-5">
          {forYou.map((item) => (
            <li class="flex items-start gap-4 font-sans text-sm leading-relaxed text-cream md:text-base">
              <svg
                width="14"
                height="14"
                viewBox="0 0 14 14"
                aria-hidden="true"
                class="mt-[0.4em] shrink-0"
              >
                <path
                  d="M2 7.5 L5.5 11 L12 3.5"
                  fill="none"
                  stroke="#B8964B"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="md:pl-12">
        <h2 class="font-serif text-2xl font-normal text-muted md:text-3xl">
          This isn&rsquo;t for you if
        </h2>
        <ul class="mt-8 space-y-5">
          {notForYou.map((item) => (
            <li class="flex items-start gap-4 font-sans text-sm leading-relaxed text-muted md:text-base">
              <svg
                width="14"
                height="14"
                viewBox="0 0 14 14"
                aria-hidden="true"
                class="mt-[0.4em] shrink-0"
              >
                <path
                  d="M3 3 L11 11 M11 3 L3 11"
                  fill="none"
                  stroke="#9A9A9A"
                  stroke-width="1.25"
                  stroke-linecap="round"
                />
              </svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
