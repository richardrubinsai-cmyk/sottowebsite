---
const forYou = [
  "You run a UK digital marketing agency with 2–10 people.",
  "Leads, proposals, and reporting eat the days you should be selling.",
  "You'd rather own the systems than hire another operator.",
  "You want it live in days, not a six-month consultancy.",
];

const notForYou = [
  "You're a 30+ person agency with an in-house ops team.",
  "You're shopping for a free playbook or DIY course.",
  "You want bespoke enterprise integrations on a 6-week timeline.",
];
---

<section id="fit" class="section-band section-band--fit reveal px-6 py-28 md:py-40">
  <div class="mx-auto max-w-content">
    <div class="text-center"><p class="eyebrow" style="display:inline-flex;">Fit Check</p></div>

    <div class="relative mt-16 grid grid-cols-1 gap-16 md:grid-cols-2 md:gap-16">
      <!-- vertical brass divider, desktop only -->
      <div
        class="pointer-events-none absolute left-1/2 top-0 hidden h-full w-px -translate-x-1/2 md:block"
        style="background-color: rgba(184,150,75,0.2);"
        aria-hidden="true"
      ></div>

      <div class="md:pr-12">
        <h2 class="font-serif text-2xl font-normal text-cream md:text-3xl">
          This is for you if
        </h2>
        <ul class="mt-8 space-y-5">
          {forYou.map((item) => (
            <li class="flex items-start gap-4 font-sans text-sm leading-relaxed text-cream md:text-base">
              <svg
                width="14"
                height="14"
                viewBox="0 0 14 14"
                aria-hidden="true"
                class="mt-[0.4em] shrink-0"
              >
                <path
                  d="M2 7.5 L5.5 11 L12 3.5"
                  fill="none"
                  stroke="#B8964B"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="md:pl-12">
        <h2 class="font-serif text-2xl font-normal text-muted md:text-3xl">
          This isn&rsquo;t for you if
        </h2>
        <ul class="mt-8 space-y-5">
          {notForYou.map((item) => (
            <li class="flex items-start gap-4 font-sans text-sm leading-relaxed text-muted md:text-base">
              <svg
                width="14"
                height="14"
                viewBox="0 0 14 14"
                aria-hidden="true"
                class="mt-[0.4em] shrink-0"
              >
                <path
                  d="M3 3 L11 11 M11 3 L3 11"
                  fill="none"
                  stroke="#9A9A9A"
                  stroke-width="1.25"
                  stroke-linecap="round"
                />
              </svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 767px) {
    #fit .relative {
      margin-top: 44px;
      gap: 44px;
    }

    #fit h2 {
      font-size: 28px;
      line-height: 1.12;
    }

    #fit ul {
      margin-top: 22px;
    }

    #fit li {
      gap: 12px;
      font-size: 15px;
      line-height: 1.55;
    }
  }
</style>
