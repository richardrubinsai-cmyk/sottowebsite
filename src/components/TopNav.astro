<nav class="top-nav" aria-label="Primary">
  <div class="top-nav__inner">
    <a href="/" aria-label="Sotto — home" class="top-nav__brand">Sotto</a>
    <a href="#waitlist" class="top-nav__cta">Join Waitlist</a>
  </div>
</nav>

<style>
  .top-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    width: 100%;
    height: 72px;
    z-index: 100;
    background: rgba(8, 8, 10, 0.55);
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .top-nav__inner {
    max-width: 1400px;
    margin: 0 auto;
    height: 100%;
    padding: 0 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .top-nav__brand {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 400;
    letter-spacing: 0.02em;
    color: var(--color-cream);
    text-decoration: none;
    font-variation-settings: "opsz" 96;
  }
  .top-nav__cta {
    display: inline-block;
    padding: 10px 22px;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: #B8964B;
    background: transparent;
    border: 1px solid rgba(184, 150, 75, 0.5);
    text-decoration: none;
    transition: background-color 220ms ease, box-shadow 220ms ease, border-color 220ms ease;
  }
  .top-nav__cta:hover {
    background: rgba(184, 150, 75, 0.08);
    box-shadow: 0 0 16px rgba(184, 150, 75, 0.25);
    border-color: rgba(184, 150, 75, 0.8);
  }
</style>
