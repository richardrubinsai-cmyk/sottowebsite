<nav class="top-nav" aria-label="Primary">
  <div class="top-nav__inner">
    <a href="/" aria-label="Sotto — home" class="top-nav__brand">
      <span class="top-nav__wordmark">Sotto</span>
    </a>

    <div class="top-nav__links" aria-label="Sections">
      <a href="#stack">Stack</a>
      <a href="#fit">Fit</a>
      <a href="#waitlist">Access</a>
    </div>

    <a href="#waitlist" class="top-nav__cta">Join Waitlist</a>
  </div>
</nav>

<style>
  .top-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    width: 100%;
    height: 82px;
    z-index: 100;
    padding: 20px 32px 0;
    pointer-events: none;
  }
  .top-nav__inner {
    position: relative;
    max-width: 1400px;
    margin: 0 auto;
    height: 48px;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    pointer-events: auto;
    background: transparent;
  }
  .top-nav__inner::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -10px;
    height: 1px;
    background: linear-gradient(90deg, rgba(184, 150, 75, 0.72), rgba(49, 92, 168, 0.28), transparent 72%);
    pointer-events: none;
    opacity: 0.75;
  }
  .top-nav__brand {
    display: inline-flex;
    align-items: center;
    gap: 13px;
    font-family: var(--font-display);
    font-weight: 400;
    color: var(--color-cream);
    text-decoration: none;
    white-space: nowrap;
  }
  .top-nav__wordmark {
    font-size: 24px;
    letter-spacing: 0.18em;
    font-variation-settings: "opsz" 144;
    text-shadow: 0 12px 32px rgba(0, 0, 0, 0.55);
  }
  .top-nav__links {
    position: absolute;
    left: 50%;
    display: flex;
    align-items: center;
    gap: 4px;
    transform: translateX(-50%);
  }
  .top-nav__links a {
    padding: 8px 11px;
    color: rgba(245, 241, 232, 0.58);
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-decoration: none;
    text-transform: uppercase;
    transition: color 180ms ease, background-color 180ms ease;
  }
  .top-nav__links a:hover {
    color: var(--color-cream);
  }
  .top-nav__cta {
    display: inline-block;
    padding: 10px 0 10px 20px;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: #B8964B;
    background: transparent;
    border-left: 1px solid rgba(184, 150, 75, 0.42);
    text-decoration: none;
    transition: color 220ms ease, border-color 220ms ease;
  }
  .top-nav__cta:hover {
    color: var(--color-cream);
    border-color: rgba(184, 150, 75, 0.86);
  }

  @media (max-width: 760px) {
    .top-nav {
      height: 74px;
      padding: 18px 18px 0;
    }
    .top-nav__inner {
      height: 44px;
    }
    .top-nav__links {
      display: none;
    }
    .top-nav__wordmark {
      font-size: 20px;
    }
    .top-nav__cta {
      padding: 9px 0 9px 14px;
      letter-spacing: 0.12em;
    }
  }
</style>
