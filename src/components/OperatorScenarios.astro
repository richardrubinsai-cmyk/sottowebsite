---
const scenarios = [
  {
    role: "The Solo-Founder Agency",
    moment: "I’m the owner, the salesperson, and the operator. Leads pile up while I’m on calls.",
    outcome: "We take the operational layer off your plate. Lead capture, follow-up, proposals — all running while you sell.",
  },
  {
    role: "The Growing Agency (3–6)",
    moment: "We hired a project manager last year. We need them on client work, not chasing leads.",
    outcome: "We give your team the systems to scale without adding another hire. The work moves itself; your team handles strategy.",
  },
  {
    role: "The Established Agency (7–10)",
    moment: "Our processes were built when we were three people. They don’t work at ten.",
    outcome: "We rebuild the back-office layer for how you actually operate now. One install, then maintained forever.",
  },
];
---

<section class="section-band section-band--scenarios reveal px-6 py-28 md:py-40">
  <div class="mx-auto max-w-6xl">
    <div class="mx-auto max-w-content text-center">
      <p class="eyebrow" style="display:inline-flex;">Agency Scenarios</p>
      <h2 class="mt-6 font-serif text-4xl font-normal leading-tight text-cream md:text-5xl">
        Built around the agency you actually run.
      </h2>
      <p class="mx-auto mt-5 max-w-[35rem] font-sans text-base leading-relaxed text-muted md:text-lg">
        Three agency shapes we see most. The build is the same; what changes is what we take off your plate first.
      </p>
    </div>

    <div class="scenario-grid mt-16">
      {scenarios.map((scenario) => (
        <article class="scenario-card">
          <span>{scenario.role}</span>
          <p class="scenario-card__moment">&ldquo;{scenario.moment}&rdquo;</p>
          <div class="scenario-card__line" aria-hidden="true"></div>
          <p class="scenario-card__outcome">{scenario.outcome}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .scenario-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid rgba(245, 241, 232, 0.08);
    border-left: 1px solid rgba(245, 241, 232, 0.08);
  }

  .scenario-card {
    min-height: 340px;
    padding: 30px;
    border-right: 1px solid rgba(245, 241, 232, 0.08);
    border-bottom: 1px solid rgba(245, 241, 232, 0.08);
    background:
      linear-gradient(180deg, rgba(245, 241, 232, 0.035), transparent 55%),
      rgba(8, 8, 8, 0.22);
  }

  .scenario-card span {
    color: var(--color-brass);
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .scenario-card__moment {
    margin: 52px 0 0;
    color: var(--color-cream);
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 400;
    line-height: 1.18;
    letter-spacing: -0.01em;
  }

  .scenario-card__line {
    width: 44px;
    height: 1px;
    margin-top: 30px;
    background: rgba(184, 150, 75, 0.58);
  }

  .scenario-card__outcome {
    margin: 26px 0 0;
    color: var(--color-muted);
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.65;
  }

  @media (max-width: 900px) {
    .scenario-grid {
      grid-template-columns: 1fr;
    }

    .scenario-card {
      min-height: auto;
    }

    .scenario-card__moment {
      margin-top: 34px;
    }
  }

  @media (max-width: 767px) {
    .scenario-grid {
      margin-top: 44px;
    }

    .scenario-card {
      padding: 22px;
    }

    .scenario-card__moment {
      margin-top: 28px;
      font-size: 24px;
      line-height: 1.18;
    }

    .scenario-card__line {
      margin-top: 24px;
    }

    .scenario-card__outcome {
      margin-top: 22px;
      font-size: 13px;
      line-height: 1.62;
    }
  }
</style>
