---
---

<section id="contact" class="section-band section-band--waitlist reveal px-6 py-28 md:py-40">
  <div class="contact-inner mx-auto text-center">

    <p class="eyebrow" style="display:inline-flex;">Audit Call</p>
    <h2 class="mt-6 font-serif text-4xl font-normal leading-tight text-cream md:text-5xl">
      Let&rsquo;s see if there&rsquo;s a fit.
    </h2>
    <p class="mx-auto mt-5 max-w-[34rem] font-sans text-base leading-relaxed text-muted">
      15-minute audit call. No pitch. We look at your current setup, show you the 2&ndash;3 things we&rsquo;d automate first, and you decide if it&rsquo;s worth a build.
    </p>

    <div class="contact-cta-wrap mt-12">
      <a
        href="https://calendly.com/bysottoco/30min"
        target="_blank"
        rel="noopener noreferrer"
        class="contact-cta"
      >
        Book a 15-min audit call
      </a>
    </div>

  </div>
</section>

<style>
  .contact-inner {
    max-width: 640px;
  }

  .contact-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 280px;
    height: 56px;
    padding: 0 32px;
    border: 1px solid var(--color-brass);
    background: var(--color-brass);
    color: var(--color-bg);
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    text-decoration: none;
    transition: background-color 260ms ease, color 260ms ease;
  }

  .contact-cta:hover {
    background: transparent;
    color: var(--color-brass);
  }

  @media (max-width: 600px) {
    .contact-cta {
      width: 100%;
      min-width: 0;
      height: 58px;
      font-size: 12px;
      letter-spacing: 0.16em;
    }
  }
</style>
