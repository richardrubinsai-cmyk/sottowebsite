---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Terms — Sotto" description="Sotto terms of service.">
  <main class="px-6 py-28 md:py-40">
    <div class="mx-auto max-w-content">
      <a href="/" class="font-serif text-xl tracking-[0.22em] text-cream">Sotto</a>
      <p class="mt-16 font-sans text-[11px] uppercase tracking-[0.28em] text-brass">Terms</p>
      <h1 class="mt-6 font-serif text-4xl font-normal text-cream md:text-5xl">Coming soon.</h1>
      <p class="mt-8 font-sans text-base leading-relaxed text-muted">
        For any questions, email <a class="text-brass hover:underline" href="mailto:hello@bysotto.com">hello@bysotto.com</a>.
      </p>
    </div>
  </main>
  <Footer />
</BaseLayout>
