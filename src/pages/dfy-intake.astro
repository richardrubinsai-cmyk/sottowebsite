---
import "../styles/global.css";

const tools = [
  "Gmail",
  "Google Sheets",
  "Notion",
  "Airtable",
  "Stripe",
  "Calendly",
  "Telegram",
  "WhatsApp Business",
  "Other",
];

const n8nOptions = [
  { value: "yes", label: "Yes" },
  { value: "no", label: "No" },
  { value: "whats_n8n", label: "What's n8n?" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>Done For You — Sotto</title>
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#0A0A0A" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" sizes="32x32" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600&family=Inter+Tight:wght@300;400;500;600&display=swap"
    />
  </head>

  <body>
    <main class="intake-page">

      <!-- Wordmark -->
      <header class="intake-header">
        <a href="/" aria-label="Sotto — home" class="intake-wordmark">Sotto</a>
      </header>

      <!-- Intro -->
      <div class="intake-intro">
        <p class="eyebrow">Done For You</p>
        <h1>Let's build your system.</h1>
        <p class="intake-subtext">
          Fill this in so we can hit the ground running. Your kickoff call link will arrive
          by email within 24 hours.
        </p>
      </div>

      <!-- Form -->
      <form id="dfy-form" novalidate autocomplete="on">

        <!-- Honeypot — bots fill this; humans don't see it -->
        <input
          type="text"
          name="website_url"
          class="hp-field"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
        />

        <div class="form-stack">

          <!-- Full name -->
          <div class="intake-field">
            <label for="f-name">Full name</label>
            <div class="form-field">
              <input type="text" id="f-name" name="name" required autocomplete="name" />
              <span class="focus-bar" aria-hidden="true"></span>
            </div>
          </div>

          <!-- Business name -->
          <div class="intake-field">
            <label for="f-business">Business name</label>
            <div class="form-field">
              <input type="text" id="f-business" name="business_name" required autocomplete="organization" />
              <span class="focus-bar" aria-hidden="true"></span>
            </div>
          </div>

          <!-- Website / Instagram -->
          <div class="intake-field">
            <label for="f-website">Website or Instagram URL</label>
            <div class="form-field">
              <input type="text" id="f-website" name="website" required autocomplete="url" />
              <span class="focus-bar" aria-hidden="true"></span>
            </div>
          </div>

          <!-- Email -->
          <div class="intake-field">
            <label for="f-email">Best email to reach you</label>
            <div class="form-field">
              <input type="email" id="f-email" name="email" required autocomplete="email" />
              <span class="focus-bar" aria-hidden="true"></span>
            </div>
          </div>

          <!-- Phone -->
          <div class="intake-field">
            <label for="f-phone">Phone number</label>
            <div class="form-field">
              <input type="tel" id="f-phone" name="phone" required autocomplete="tel" />
              <span class="focus-bar" aria-hidden="true"></span>
            </div>
          </div>

          <!-- What does your business do -->
          <div class="intake-field">
            <label for="f-what">What does your business do?</label>
            <div class="form-field">
              <textarea
                id="f-what"
                name="what_you_do"
                rows="3"
                required
                placeholder="One or two sentences is fine"
              ></textarea>
              <span class="focus-bar" aria-hidden="true"></span>
            </div>
          </div>

          <!-- Tools checkbox grid -->
          <fieldset class="intake-fieldset">
            <legend>Tools you currently use</legend>
            <div class="tools-grid">
              {tools.map((tool) => (
                <label class="tool-check">
                  <input type="checkbox" name="tools" value={tool} />
                  <span class="check-box" aria-hidden="true"></span>
                  <span class="check-label">{tool}</span>
                </label>
              ))}
            </div>
          </fieldset>

          <!-- Automate first -->
          <div class="intake-field">
            <label for="f-automate">Three things you want automated first</label>
            <div class="form-field">
              <textarea
                id="f-automate"
                name="automate_first"
                rows="4"
                required
                placeholder="e.g. lead follow-up, invoice chasing, content scheduling"
              ></textarea>
              <span class="focus-bar" aria-hidden="true"></span>
            </div>
          </div>

          <!-- n8n status -->
          <fieldset class="intake-fieldset">
            <legend>Do you have an n8n account?</legend>
            <div class="radio-group">
              {n8nOptions.map(({ value, label }, i) => (
                <label class="radio-label">
                  <input
                    type="radio"
                    name="n8n_status"
                    value={value}
                    required={i === 0}
                  />
                  <span class="radio-dot" aria-hidden="true"></span>
                  <span class="radio-text">{label}</span>
                </label>
              ))}
            </div>
          </fieldset>

        </div><!-- /form-stack -->

        <!-- Error message -->
        <p id="form-error" class="form-error" aria-live="polite" hidden>
          Something went wrong. Email us at&nbsp;<a href="mailto:hello@bysotto.com">hello@bysotto.com</a>
        </p>

        <!-- Submit -->
        <button type="submit" id="submit-btn" class="submit-btn">
          <span id="submit-label">Send My Brief →</span>
        </button>

      </form>

      <!-- Success state — shown after successful POST -->
      <div id="success-state" class="success-state" hidden aria-live="polite">
        <div class="success-rule" aria-hidden="true"></div>
        <h2>Brief received.</h2>
        <p>
          We'll review your answers and send your kickoff call link within 24 hours.
          Check your inbox — including spam.
        </p>
      </div>

    </main>

    <script>
      const form = document.getElementById("dfy-form") as HTMLFormElement;
      const successState = document.getElementById("success-state") as HTMLElement;
      const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
      const submitLabel = document.getElementById("submit-label") as HTMLElement;
      const errorEl = document.getElementById("form-error") as HTMLElement;

      form.addEventListener("submit", async (e) => {
        e.preventDefault();

        // Honeypot — silently succeed if filled
        const hp = (form.elements.namedItem("website_url") as HTMLInputElement).value;
        if (hp) {
          form.hidden = true;
          successState.hidden = false;
          return;
        }

        // Collect checked tools
        const checkedTools = Array.from(
          form.querySelectorAll<HTMLInputElement>('input[name="tools"]:checked')
        ).map((cb) => cb.value);

        // Collect n8n status
        const n8nEl = form.querySelector<HTMLInputElement>('input[name="n8n_status"]:checked');

        const payload = {
          name: (form.elements.namedItem("name") as HTMLInputElement).value.trim(),
          business_name: (form.elements.namedItem("business_name") as HTMLInputElement).value.trim(),
          website: (form.elements.namedItem("website") as HTMLInputElement).value.trim(),
          email: (form.elements.namedItem("email") as HTMLInputElement).value.trim(),
          phone: (form.elements.namedItem("phone") as HTMLInputElement).value.trim(),
          what_you_do: (form.elements.namedItem("what_you_do") as HTMLTextAreaElement).value.trim(),
          tools: checkedTools,
          automate_first: (form.elements.namedItem("automate_first") as HTMLTextAreaElement).value.trim(),
          n8n_status: n8nEl ? n8nEl.value : "",
        };

        submitBtn.disabled = true;
        submitLabel.textContent = "Sending…";
        errorEl.hidden = true;

        try {
          const res = await fetch("https://n8n.bysotto.com/webhook/dfy-intake", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          });

          if (!res.ok) throw new Error(`HTTP ${res.status}`);

          form.hidden = true;
          successState.hidden = false;
          successState.focus();
        } catch {
          errorEl.hidden = false;
          submitBtn.disabled = false;
          submitLabel.textContent = "Send My Brief →";
          errorEl.scrollIntoView({ behavior: "smooth", block: "nearest" });
        }
      });
    </script>
  </body>
</html>

<style>
  /* ── Page shell ── */
  .intake-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 52px 24px 96px;
  }

  /* ── Wordmark ── */
  .intake-header {
    width: 100%;
    max-width: 560px;
    margin-bottom: 72px;
  }

  .intake-wordmark {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 400;
    letter-spacing: 0.2em;
    color: var(--color-cream);
    text-decoration: none;
    font-variation-settings: "opsz" 144;
    transition: color 200ms ease;
  }

  .intake-wordmark:hover {
    color: var(--color-brass);
  }

  /* ── Intro ── */
  .intake-intro {
    width: 100%;
    max-width: 560px;
    margin-bottom: 60px;
  }

  .intake-intro h1 {
    margin: 20px 0 0;
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 7vw, 3rem);
    font-weight: 400;
    color: var(--color-cream);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-variation-settings: "opsz" 144;
  }

  .intake-subtext {
    margin: 18px 0 0;
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.7;
    color: var(--color-muted);
  }

  /* ── Form ── */
  #dfy-form {
    width: 100%;
    max-width: 560px;
  }

  .form-stack {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  /* ── Individual field ── */
  .intake-field {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .intake-field label {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgba(245, 241, 232, 0.48);
  }

  .intake-field input,
  .intake-field textarea {
    width: 100%;
    padding: 0 0 14px;
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(245, 241, 232, 0.13);
    color: var(--color-cream);
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.55;
    resize: vertical;
    -webkit-appearance: none;
    appearance: none;
    outline: none;
  }

  .intake-field input::placeholder,
  .intake-field textarea::placeholder {
    color: rgba(245, 241, 232, 0.2);
  }

  /* Autofill override */
  .intake-field input:-webkit-autofill,
  .intake-field input:-webkit-autofill:focus {
    -webkit-box-shadow: 0 0 0 100px #0a0a0a inset;
    -webkit-text-fill-color: var(--color-cream);
    caret-color: var(--color-cream);
  }

  /* ── Fieldsets ── */
  .intake-fieldset {
    border: none;
    padding: 0;
    margin: 0;
  }

  .intake-fieldset legend {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgba(245, 241, 232, 0.48);
    margin-bottom: 20px;
  }

  /* ── Tools checkbox grid ── */
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }

  .tool-check {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 11px 12px;
    border: 1px solid rgba(245, 241, 232, 0.1);
    cursor: pointer;
    transition: border-color 180ms ease, background-color 180ms ease;
    user-select: none;
  }

  .tool-check:hover {
    border-color: rgba(184, 150, 75, 0.38);
    background: rgba(184, 150, 75, 0.04);
  }

  .tool-check input[type="checkbox"] {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  .check-box {
    flex-shrink: 0;
    width: 13px;
    height: 13px;
    border: 1px solid rgba(245, 241, 232, 0.28);
    background: transparent;
    transition: background 180ms ease, border-color 180ms ease;
  }

  .tool-check input:checked ~ .check-box {
    background: var(--color-brass);
    border-color: var(--color-brass);
  }

  /* Checkmark inside the box */
  .tool-check input:checked ~ .check-box::after {
    content: '';
    display: block;
    width: 100%;
    height: 100%;
    background: url("data:image/svg+xml,%3Csvg viewBox='0 0 13 13' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M2.5 6.5l3 3 5-5' stroke='%230A0A0A' stroke-width='1.8' fill='none' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E") center / 11px no-repeat;
  }

  .tool-check input:focus-visible ~ .check-box {
    outline: 2px solid var(--color-brass);
    outline-offset: 2px;
  }

  .check-label {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 400;
    color: rgba(245, 241, 232, 0.65);
    line-height: 1.3;
  }

  .tool-check input:checked ~ .check-label {
    color: var(--color-cream);
  }

  /* ── Radio group ── */
  .radio-group {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .radio-label {
    display: flex;
    align-items: center;
    gap: 14px;
    cursor: pointer;
    user-select: none;
  }

  .radio-label input[type="radio"] {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  .radio-dot {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    border: 1px solid rgba(245, 241, 232, 0.28);
    border-radius: 50%;
    position: relative;
    transition: border-color 180ms ease;
  }

  .radio-dot::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0);
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-brass);
    transition: transform 200ms ease;
  }

  .radio-label input:checked ~ .radio-dot {
    border-color: var(--color-brass);
  }

  .radio-label input:checked ~ .radio-dot::after {
    transform: translate(-50%, -50%) scale(1);
  }

  .radio-label input:focus-visible ~ .radio-dot {
    outline: 2px solid var(--color-brass);
    outline-offset: 3px;
  }

  .radio-text {
    font-family: var(--font-body);
    font-size: 14px;
    color: rgba(245, 241, 232, 0.72);
    transition: color 180ms ease;
  }

  .radio-label input:checked ~ .radio-text {
    color: var(--color-cream);
  }

  /* ── Error ── */
  .form-error {
    margin-top: 24px;
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.55;
    color: #c9453d;
  }

  .form-error a {
    color: var(--color-brass);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ── Submit button ── */
  .submit-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 56px;
    margin-top: 52px;
    background: var(--color-brass);
    color: var(--color-bg);
    border: none;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    cursor: pointer;
    transition: background-color 220ms ease, opacity 200ms ease;
  }

  .submit-btn:hover:not(:disabled) {
    background: #c9a85a;
  }

  .submit-btn:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  /* ── Success state ── */
  .success-state {
    width: 100%;
    max-width: 560px;
    padding-top: 12px;
    outline: none;
  }

  .success-rule {
    width: 40px;
    height: 1px;
    background: var(--color-brass);
    margin-bottom: 36px;
    opacity: 0.7;
  }

  .success-state h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 2.8rem);
    font-weight: 400;
    color: var(--color-cream);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0 0 20px;
    font-variation-settings: "opsz" 96;
  }

  .success-state p {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-muted);
  }

  /* ── Honeypot ── */
  .hp-field {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
  }

  /* ── Mobile ── */
  @media (max-width: 600px) {
    .intake-page {
      padding: 40px 20px 72px;
    }

    .intake-header {
      margin-bottom: 52px;
    }

    .intake-intro {
      margin-bottom: 48px;
    }

    .intake-wordmark {
      font-size: 20px;
      letter-spacing: 0.16em;
    }

    .tools-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .form-stack {
      gap: 32px;
    }

    .submit-btn {
      height: 58px;
      margin-top: 44px;
    }
  }
</style>
